# Пример переменных окружения для CyberTeacher

# Для OpenRouter провайдера (если LLM_PROVIDER="openrouter")
OPENROUTER_API_KEY=sk-or-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# Бесплатные/дешевые модели с большим контекстом:
# - nvidia/nemotron-3-nano-30b-a3b:free (256K, 30B, бесплатно)
# - mistralai/mixtral-8x7b-instruct (32K, бесплатно)
# - meta-llama/llama-3.2-3b-instruct (8K, бесплатно)
# Платные (качество GPT-4):
# - anthropic/claude-3.5-sonnet (200K, ~$0.003/1K вх)
# - openai/gpt-4o (128K, ~$0.002/1K вх)

# Для Ollama провайдера (локально) ничего не нужно, если запущен ollama serve
